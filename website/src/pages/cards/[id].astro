---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ImageZoom from '../../components/ImageZoom.svelte';
import Markdown from '../../components/Markdown.astro';
import RichText from '../../components/RichText.astro';
import {
  catalog,
  cardsById,
  sectionsBySlug,
  formatDate,
  withBase,
} from '../../lib/catalog';

export function getStaticPaths() {
  return catalog.cards.map((card) => ({
    params: { id: card.id },
    props: { card },
  }));
}
const { card } = Astro.props;
const section = sectionsBySlug.get(card.sectionSlug)!;
const sectionCards = section.cardIds
  .map((id) => cardsById.get(id)!)
  .filter(Boolean);
const index = sectionCards.findIndex((candidate) => candidate.id === card.id);
const previous =
  sectionCards[(index - 1 + sectionCards.length) % sectionCards.length]!;
const next = sectionCards[(index + 1) % sectionCards.length]!;
const related = sectionCards
  .filter((candidate) => candidate.id !== card.id)
  .sort((a, b) => a.id.localeCompare(b.id))
  .slice(0, 3);
const base = import.meta.env.BASE_URL;
const render = withBase(base, card.render);
const explanation = catalog.explanations[card.id];
---

<BaseLayout
  title={`${card.name} — YGO × MTG`}
  description={`${card.name}: ${card.superType}. ${card.ruleTextPlain.slice(0, 130)}`}
  image={card.render}
  accent={section.accent}
  theme={section.slug}
>
  <article class="page-shell card-detail">
    <div class="render-column">
      <picture>
        <source srcset={withBase(base, card.galleryAvif)} type="image/avif" />
        <source srcset={withBase(base, card.galleryWebp)} type="image/webp" />
        <img
          src={render}
          alt={`${card.name} card render`}
          width={card.width}
          height={card.height}
          fetchpriority="high"
        />
      </picture>
      <ImageZoom
        client:load
        src={render}
        alt={`${card.name} card render`}
        width={card.width}
        height={card.height}
      />
    </div>
    <div class="card-transcription">
      <p><a href={withBase(base, section.route)}>{section.label}</a> / Card</p>
      <h1>{card.name}</h1>
      {
        card.castingCost && (
          <p>
            <strong>Cost:</strong> {card.castingCost}
          </p>
        )
      }
      <p class="type-line">
        {card.superType}{card.subType && ` — ${card.subType}`}
      </p>
      <RichText value={card.ruleText} class="rules-text" />
      {
        card.flavorTextPlain && (
          <RichText value={card.flavorText} class="flavor-text" />
        )
      }
      {
        card.power && card.toughness && (
          <p>
            <strong>Power / toughness:</strong> {card.power}/{card.toughness}
          </p>
        )
      }
      {
        explanation && (
          <section>
            <>
              <h2>Design notes</h2>
              <Markdown value={explanation} class="authored-explanation" />
            </>
          </section>
        )
      }
      <div class="card-facts">
        <span>Rarity: {card.rarity}</span><span
          >Collection: {card.collectionNumber}</span
        ><span>Modified {formatDate(card.modified)}</span>{
          card.support && <span>Support card</span>
        }
      </div>
      <nav class="card-pager" aria-label="Cards in manifest order">
        <a href={withBase(base, previous.route)}>← {previous.name}</a><a
          href={withBase(base, next.route)}>{next.name} →</a
        >
      </nav>
      <section>
        <h2>Related in {section.label}</h2><ul>
          {
            related.map((item) => (
              <li>
                <a href={withBase(base, item.route)}>{item.name}</a>
              </li>
            ))
          }
        </ul>
      </section>
    </div>
  </article>
</BaseLayout>
