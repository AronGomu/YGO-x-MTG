---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Not found — YGO × MTG"
  description="This archive route does not exist."
  ><section class="page-shell empty-state">
    <h1>Card not found</h1><p>
      This route is not part of the published archive. Search by card name or
      return to the catalog.
    </p><a class="primary-link" href={base}>Return to the archive</a>
  </section></BaseLayout
>
