---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import CardPicture from '../../../../components/CardPicture.astro';
import StatusBadge from '../../../../components/StatusBadge.astro';
import {
  catalog,
  sectionsBySlug,
  withBase,
  formatDate,
} from '../../../../lib/catalog';
export function getStaticPaths() {
  return catalog.snapshots.map((snapshot) => ({
    params: { slug: snapshot.sectionSlug, snapshot: snapshot.id },
    props: { snapshot },
  }));
}
const { snapshot } = Astro.props;
const section = sectionsBySlug.get(snapshot.sectionSlug)!;
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title={`${section.label} snapshot ${snapshot.id} — YGO × MTG`}
  description={`Immutable ${section.label} showcase snapshot from ${snapshot.createdOn}.`}
  accent={section.accent}
>
  <div class="page-shell">
    <header class="section-heading">
      <div>
        <p>
          <a href={withBase(base, section.route)}>{section.label}</a> / Historical
          snapshot
        </p><h1>{snapshot.id}</h1><p>
          {snapshot.selected.length} selected cards · {
            snapshot.baseline.length
          }-card lineage baseline · {
            formatDate(`${snapshot.createdOn} 12:00:00`)
          }
        </p>
      </div>
    </header>
    <ul class="update-list">
      {
        snapshot.selected.map((card, index) => (
          <li class="update-item">
            <article class="snapshot-item">
              <CardPicture {card} eager={index < 3} />
              <span class="update-meta">
                <strong>{card.name}</strong>
                <StatusBadge status={card.status} />
              </span>
            </article>
          </li>
        ))
      }
    </ul>
  </div>
</BaseLayout>
