---
import { withBase, type CatalogCard } from '../lib/catalog';
interface Props {
  card: CatalogCard;
  eager?: boolean;
  sizes?: string;
  class?: string;
}
const {
  card,
  eager = false,
  sizes = '(min-width: 70rem) 18rem, (min-width: 40rem) 30vw, 80vw',
  class: className,
} = Astro.props;
const base = import.meta.env.BASE_URL;
---

<picture class={className}>
  <source srcset={withBase(base, card.galleryAvif)} type="image/avif" />
  <source srcset={withBase(base, card.galleryWebp)} type="image/webp" />
  <img
    src={withBase(base, card.render)}
    alt=""
    width={card.width}
    height={card.height}
    loading={eager ? 'eager' : 'lazy'}
    fetchpriority={eager ? 'high' : 'auto'}
    decoding="async"
    sizes={sizes}
  />
</picture>
